# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/campushub_lost_found

# Roboflow — Get your API key at https://app.roboflow.com
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE=yaswanths-workspace-mop6p
ROBOFLOW_WORKFLOW=custom-workflow

# Ollama (ensure ollama is running: `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Matching Thresholds
STRONG_MATCH_THRESHOLD=70
POSSIBLE_MATCH_THRESHOLD=50
MIN_CONFIDENCE=0.6
TOP_MATCHES=5
